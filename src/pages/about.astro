---
// Layout import — provides basic page elements: <head>, <nav>, <footer> etc.
	import BaseLayout from '../layouts/BaseLayout.astro';

	// Component Imports
	import CallToAction from '../components/CallToAction.astro';
	import Hero from '../components/Hero.astro';
	import Icon from '../components/Icon.astro';

	// Page section components
	import ContactCTA from '../components/ContactCTA.astro';
	import CvCTA from '../components/CvCTA.astro';
	---

	<BaseLayout>
		<div class="stack">
			<div class="wrapper stack gap-8 lg:gap-20">
				<header class="profil">
					<img
							alt="Sébastien Dru, Développeur Web Freelance"
							width="2323"
							height="2322"
							src="/assets/portrait.jpg"
					/>

					<div class=" stack gap-2 start">
						<h1 class="title margin-l">Sébastien Dru</h1>
						<h2 class="subtitle margin-l">Développeur Web Freelance · Angular & Node.js</h2>
						<p class="tagline">Passionné d'informatique depuis mes études, j'ai entamé ma reconversion vers le développement web après plus de 10 ans dans le commerce. Aujourd'hui développeur indépendant (auto-entrepreneur), j'accompagne mes clients dans la conception et le développement d'applications web. J'interviens principalement sur des projets Angular et Node.js, ainsi que WordPress pour les sites vitrine.</p>
					</div>
				</header>

				<main class="details wrapper stack gap-20 lg:gap-48">
					<div class="stack gap-4 start">
						<h4 class="subtitle margin-l">Technologies</h4>
						<div>
							<h5>Front End</h5>
							<p>Angular, TypeScript, HTML, SCSS</p>
						</div>
						<div>
							<h5>Back End</h5>
							<p>Node.js, PHP, WordPress</p>
						</div>
						<div>
							<h5>Outils</h5>
							<p>GitHub, Linux, Bootstrap</p>
						</div>

					</div>
					<div class="stack gap-4 start">
						<h4 class="subtitle margin-l">Expériences</h4>
						<div>
							<h5>Développeur indépendant (auto-entrepreneur)</h5>
							<p>2023 - Actuellement</p>
							<p>Développement d'applications web en Angular et Node.js. Accompagnement client sur l'ensemble du cycle de développement, de la conception à la mise en production.</p>
						</div>
						<div>
							<h5>Stage - Networks Technology</h5>
							<p>Janvier - Février 2023 à Boulogne-Billancourt</p>
							<p>Intégration d'emails, corrections de bugs sur des projets Symfony (v3 - v5), intégration Front End.</p>
						</div>
					</div>

					<div class="stack gap-4 start">
						<h4 class="subtitle margin-l">Formations</h4>
						<div>
							<h5>Développeur d'application Bac+4
								PHP/Symfony - OpenClassRooms</h5>
							<p>2022 - 2023</p>
						</div>
						<div>
							<h5>Master d'Économie Bac+5
								- Université de Bourgogne, Dijon</h5>
							<p>2004 - 2010</p>
						</div>
						<div>
							<h5>BTS Informatique et Réseau Bac+2
								- Institut Lemonnier, Caen</h5>
							<p>2002 - 2004</p>
						</div>
					</div>
					<div class="stack gap-4 start">
						<h4 class="subtitle margin-l">Centres d'intérêt</h4>
							<p>Raspberry, Marathon, Gastronomie</p>
					</div>


				</main>
			</div>

			<CvCTA />

			<ContactCTA />
		</div>
	</BaseLayout>

	<style>

		.margin-l {
			margin-bottom: 0.5rem;
		}

		.title {
			font-size: var(--text-3xl);
			color: var(--gray-0);
		}

		.profil {
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: 2rem;
		}

		.details {
			display: flex;
			flex-direction: column;
			align-items: start;
			gap: 2rem;
		}

		.roles {

			display: none;
		}

		.profil img {
			object-fit: cover;
			object-position: top;
			border-radius: 1.5rem;
			box-shadow: var(--shadow-md);
		}

		.subtitle {
			font-size: 2.125rem;
			color: var(--accent-regular);
		}

		@media (min-width: 50em) {
			.profil {
				display: grid;
				grid-template-columns: 3fr 6fr;
				padding-inline: 2.5rem;
				gap: 3.75rem;
			}

			.details {
				display: grid;
				grid-template-columns: 1fr 1fr;
				padding-inline: 2.5rem;
				gap: 3.75rem;
				padding: 0 2rem 2rem 2rem;
			}

			.roles {
				margin-top: 0.5rem;
				display: flex;
				gap: 0.5rem;
			}

			.profil img {
				border-radius: 4.5rem;
				object-fit: cover;
			}
			.start {
				text-align: start;
			}
		}

		/* ====================================================== */

		.section {
			display: grid;
			gap: 2rem;
		}

		.with-background {
			position: relative;
		}

		.with-background::before {
			--hero-bg: var(--bg-image-subtle-2);

			content: '';
			position: absolute;
			pointer-events: none;
			left: 50%;
			width: 100vw;
			aspect-ratio: calc(2.25 / var(--bg-scale));
			top: 0;
			transform: translateY(-75%) translateX(-50%);
			background: url('/assets/backgrounds/noise.png') top center/220px repeat,
			var(--hero-bg) center center / var(--bg-gradient-size) no-repeat, var(--gray-999);
			background-blend-mode: overlay, normal, normal, normal;
			mix-blend-mode: var(--bg-blend-mode);
			z-index: -1;
		}

		.with-background.bg-variant::before {
			--hero-bg: var(--bg-image-subtle-1);
		}

		.section-header {
			justify-self: center;
			text-align: center;
			max-width: 50ch;
			font-size: var(--text-md);
			color: var(--gray-300);
		}

		.section-header h3 {
			font-size: var(--text-2xl);
		}

		@media (min-width: 50em) {
			.section {
				grid-template-columns: repeat(4, 1fr);
				grid-template-areas: 'header header header header' 'gallery gallery gallery gallery';
				gap: 5rem;
			}

			.section.with-cta {
				grid-template-areas: 'header header header cta' 'gallery gallery gallery gallery';
			}

			.section-header {
				grid-area: header;
				font-size: var(--text-lg);
			}

			.section-header h3 {
				font-size: var(--text-4xl);
			}

			.with-cta .section-header {
				justify-self: flex-start;
				text-align: left;
			}

			.gallery {
				grid-area: gallery;
			}

			.cta {
				grid-area: cta;
			}
		}

		/* ====================================================== */

		.mention-card {
			display: flex;
			height: 7rem;
			justify-content: center;
			align-items: center;
			text-align: center;
			border: 1px solid var(--gray-800);
			border-radius: 1.5rem;
			color: var(--gray-300);
			background: var(--gradient-subtle);
			box-shadow: var(--shadow-sm);
		}

		@media (min-width: 50em) {
			.mention-card {
				border-radius: 1.5rem;
				height: 9.5rem;
			}
		}
	</style>
